# Real config (only the example is committed)
# Anchored to repo root so it does not also ignore openspec/config.yaml
/config.yaml

# Secrets: API keys live in .env (e.g. GEMINI_API_KEY), never in the repo.
# Note the "env/" rule further down ignores a *directory*, not this file.
.env
.env.*
!.env.example

# Cache directory
.cache/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Test cache
.pytest_cache/

# Build artifacts
dist/
build/
*.egg-info/

# Playwright browsers
playwright-browsers/

# Virtual environments
# Glob, not a literal: this repo also has a .venv313, which ".venv/" misses.
.venv*/
venv/
env/

# Claude Code local settings
.claude/settings.local.json
