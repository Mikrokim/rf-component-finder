# ===========================================================================
#  RF datasheet-LLM config  —  put your API key below.
#  This file is loaded automatically by tools/rf_datasheet_llm.py.
#  It is git-ignored, so your key is NOT committed. Do not share it.
#  A real shell variable (if you set one) always overrides what is written here.
# ===========================================================================

# Provider: gemini | openai | local | mock
RF_LLM_PROVIDER=gemini

# Model for that provider.
#   gemini: gemini-2.5-flash (cheap/fast) | gemini-2.5-pro (higher accuracy) | gemini-3.5-flash
RF_LLM_MODEL=gemini-2.5-flash

# ---- Gemini API key -> paste your key between the quotes -------------------
GEMINI_API_KEY="AIzaSyCNwq2hNwtVh0AYt3oh90gZJ3e7kLP97Yc"

# ---- (only if you switch RF_LLM_PROVIDER to openai) ------------------------
OPENAI_API_KEY=""

# ---- (only if you switch RF_LLM_PROVIDER to local / Ollama) ----------------
RF_LLM_OLLAMA_URL=http://localhost:11434
