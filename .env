# Environment configuration for rf-component-finder.
# Loaded at startup by rf_finder/agent/skill_runner.py (via python-dotenv).

# --- Skill mode switch -------------------------------------------------------
# Controls which skills the AI Search pipeline runs:
#   test = OFFLINE test skills (rf-discovery-test / rf-verify-test) that read the
#          local mockdata/ JSON dataset. No web, no Gemini, no browsing tokens.
#   real = LIVE skills (rf-discovery / rf-verify): full web search + Gemini
#          datasheet reading (normal, full-cost run).
# Change this line and restart the app/script to switch. Default when unset: real.
RF_SKILL_MODE=real

# --- Run logging switch ------------------------------------------------------
# Controls AI Search run observability (rf_finder/agent/run_log.py):
#   on  = log the run — live console feed of actions/candidates/rejections AND a
#         durable runs/<timestamp>/events.jsonl + summary.md on disk.
#   off = no logging at all (Python discards every event). Results are identical.
# One switch controls both sinks. The skills never read this; only Python does.
# Default when unset/empty/unknown: off.
RF_LOG=on

# --- Resume switch -----------------------------------------------------------
# Controls whether a re-run of the SAME query continues from prior-run logs
# instead of starting fresh (rf_finder/agent/resume.py):
#   on  = before searching, look back at the 4 most-recent runs/<timestamp>/
#         logs; among those whose stored query (spec_text) matches this one,
#         SKIP discovery if it already finished cleanly and REUSE every verify
#         that already reached a final verdict (kept / genuine mismatch). Only
#         candidates that failed on infrastructure (dead Gemini / "insufficient
#         verification" / rate-limit) are re-verified.
#   off = ignore all logs and run everything from scratch.
# INDEPENDENT of RF_LOG: this gates READING; RF_LOG gates WRITING. Resume can
# only continue from runs that were actually logged (RF_LOG was on then); when
# on but nothing matches, the run proceeds fresh with no error.
# Default when unset/empty/unknown: off.
RF_RESUME=on
