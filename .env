# Environment configuration for rf-component-finder.
# Loaded at startup by rf_finder/agent/skill_runner.py (via python-dotenv).

# --- Skill mode switch -------------------------------------------------------
# Controls which skills the AI Search pipeline runs:
#   test = OFFLINE test skills (rf-discovery-test / rf-verify-test) that read the
#          local mockdata/ JSON dataset. No web, no Gemini, no browsing tokens.
#   real = LIVE skills (rf-discovery / rf-verify): full web search + Gemini
#          datasheet reading (normal, full-cost run).
# Change this line and restart the app/script to switch. Default when unset: real.
RF_SKILL_MODE=real
